---
interface Props {
    image: string;
    title: string;
    description: string | null;
    technologies: string[];
    repoLink: string;
    
}

const { image, title, description, technologies, repoLink } = Astro.props;

---


<div class="card-section">
    
        <div class="card-container">
            <div class="card">
                <img src={image} alt="Imagen del proyecto" />
            </div>

            <div class="description-container">
                <h3>{title}</h3>
                <p>{description}</p>
                <div class="technologies">
                        {technologies.map((tech) => <span>{tech}</span>)} 
                </div>
            </div>
            
        </div>
        <div class="git-icon">
            <a href={repoLink} target="_blank">
                <i class="fa-brands fa-github"></i>
            </a>
        </div>
    
</div>



<style>
    
   .card-section{
    display: flex;
    flex-direction: column;
    align-items: center;
   }

   .card-container{
    display: flex;
    flex-direction: column;
    width: 400px;
    color: #fff;
    font-family: Raleway, sans-serif;
   }

   .card{
    display: flex;
    justify-content: center;
    align-items: flex-end;
    width: 400px;
    height: 320px;
   }

   @media(max-width: 500px){
        .card{
            width: 100%;
            height: 100%;
        }
        .card-container{
        width: 300px;
        }
   }
   
   .card img{
    width: 100%;
    height: 100%;
    object-fit: cover;
   }

   .description-container{
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    align-content: center;
    flex-wrap: wrap;
    padding: 10px 5px 0;
   }

   .description-container h3{
    margin: 0;
    font-size: 1.3rem;
    text-transform: uppercase;
    background-image: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
	-webkit-background-clip: text;
	-webkit-text-fill-color: transparent;
   }

   .description-container p{
    font-size: .9rem;
    text-align: center;
    letter-spacing: 0.05em;
   }

   .technologies{
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    align-content: center;
    padding: 7px 0;
   }

   .technologies span{
    line-height: 25px;
    position: relative;
    margin: 0 16px 10px 0;
    padding: 0 10px 0 12px;
    background: #0008;
    color: #fff;
    font-size: .9rem;
   }

   .technologies span::before{
    content: "";
    position: absolute;
    left: -12px;
    border-color: transparent #00000088 transparent transparent;
    border-style: solid;
    border-width: 12px 12px 12px 0;
   }

   .git-icon{
    font-size: 40px;
    transition: transform .3s ease;
   }

   .git-icon:hover{
    transform: translateY(-7px);
   }

   .git-icon i{
    background-image: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
	-webkit-background-clip: text;
	-webkit-text-fill-color: transparent;
   }
   
</style>
