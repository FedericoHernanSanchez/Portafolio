---

import CardComponent from "./Card-component.astro";


const proyects = [
{
    image: "images/proyects/a.webp",
    title: "Pokedex",
    description: "Pagina donde podras encontrar todos los pokemones, desarrollado como proyecto personal full stack utilizando React y Node.js.",
    technologies: ["React", "HTML5", "CSS", "Node.js", "Express", "MySQL"],
    repoLink: "https://github.com/FedericoHernanSanchez",
    tipo : "proyect"
  },
  {
    image: "images/proyects/b.webp",
    title: "Spotify Clone",
    description: "Clon de spotify Web desarrollado como proyecto personal fullstack utilizando Angular y Node.js.",
    technologies: ["React", "Node.js", "Tailwind","CSS"],
    repoLink: "https://github.com/FedericoHernanSanchez",
    tipo :"proyect"
  }
];

---

<div class="cards-container">
    {proyects.map((proyect) => (
        <CardComponent {...proyect} />
    ))}
</div>

<style>

  .cards-container{
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 100%;
    max-width: 1100px;
    justify-items: center;
    place-content: center; /* Es lo mismo que aling content y justify content*/
    gap: 30px 20px;
  }

  @media (max-width: 950px){
    .cards-container{
      grid-template-columns: 1fr;
    }
  }
  
</style>