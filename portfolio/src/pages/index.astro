		<section id="contacto" class="contacto">
			<div class="contact-container">
				<h2>Contacto</h2>
				<form
					class="form-container"
					id="contactForm"
					method="POST"
					action="https://formspree.io/f/xovjyagw"
				>
				<div class="form-group">
					<label class="label" for="name">Nombre y Apellido</label>
					<input
						class="input"
						type="text"
						placeholder="Nombre y Apellido"
						name="name"
						id="name"
						required
					/>
				</div>
				<div class="form-group">
					<label class="label" for="email">Email</label>
					<input
						class="input"
						type="text"
						placeholder="example@gmail.com"
						name="email"
						id="email"
						required
					/>
				</div>
				<div class="form-group">
					<label class="label" for="message">Mensaje</label>
					<textarea
						class="textarea"
						name="message"
						placeholder="Escriba su mensaje aqui"
						id="message"
						required></textarea>
				</div>
					<button class="form-buttom" type="submit">Enviar</button>
				</form>
			<!--Modal -->
			<div class="modal">
				<div class="modal-content">
					<span id="closeModal" class="close">×</span>
					<p>Mensaje enviado! Me pondre en contacto a la brevedad.</p>
					<span class="text">Muchas Gracias!</span>
				</div>
			</div>
		</div>
		<script>
			document.addEventListener("DOMContentLoaded",function(){
				const form = document.getElementById("contactForm");
				const modal = document.querySelector(".modal");
				const modalMessage = document.querySelector(".modal-content p");
				const closeModal = document.getElementById("closeModal");

				form?.addEventListener("submit",async function(event){
					event.preventDefault();
					const formData = new FormData(form as HTMLFormElement);

					try{
						const response = await fetch((form as HTMLFormElement).action,{
							method: "POST",
							body: formData,
							headers: {
								Accept: "application/json",
							},
						});
						if(response.ok){
							const data = await response.json();
							if (modalMessage) {
								modalMessage.textContent = data.message || "Mensaje enviado! Me pondré en contacto a la brevedad.";
							}
							if (modal) {
								(modal as HTMLElement).style.display = "block";
							}
							(form as HTMLFormElement).reset();
						}else{
							if (modalMessage) {
								modalMessage.textContent = "Error al enviar el mensaje. Por favor, intenta nuevamente."
							}
						}
					}catch(error){
						if (modalMessage) {
							modalMessage.textContent = "Error al enviar el mensaje,Por favor, intentelo de nuevo mas tarde";
						}
					}
					if (modal) {
						(modal as HTMLElement).style.display = "flex";
					}
				});
				closeModal?.addEventListener("click",function(){
					if (modal) {
						(modal as HTMLElement).style.display = "none";
					}
				});
			});
		</script>
