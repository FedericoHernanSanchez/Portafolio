			<script>
				if (document) {
					const menuIcon = document.querySelector(".header i");
					const menu = document.querySelector(".menu");
					const menuLinks = document.querySelectorAll(".menu .a");
			
					// Función para abrir/cerrar el menú
					menuIcon?.addEventListener("click", function () {
						if (menu) {
							const isMenuOpen = (menu as HTMLElement).style.display === "flex";
							(menu as HTMLElement).style.display = isMenuOpen ? "none" : "flex";
							document.body.style.overflow = isMenuOpen ? "auto" : "hidden"; // Alterna el scroll
						}
					});
			
					// Función para cerrar el menú en móvil al hacer clic en un enlace
					menuLinks.forEach(link => {
						link.addEventListener("click", function () {
							if (window.innerWidth < 950) { 
								if (menu) {
									(menu as HTMLElement).style.display = "none";
								}
								document.body.style.overflow = "auto"; // Restablece el scroll
							}
						});
					});

					// Evento para detectar el cambio de tamaño de pantalla
					window.addEventListener("resize", function () {
						if (window.innerWidth > 950) {
							if (menu) {
								(menu as HTMLElement).style.display = "flex"; // Mostrar el menú en pantallas grandes
							}
							document.body.style.overflow = "auto"; // Restablece el scroll
						} else {
							if (menu) {
								(menu as HTMLElement).style.display = "none"; // Ocultar el menú en móvil
							}
						}
					});
				}
			</script>
