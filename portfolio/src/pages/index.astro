		gap: 10px;
		position: relative;
		white-space: nowrap;
		padding: 15px 17px	
	}

	.a{
		position: relative;
	}

	.a::after{
		content: "";
		position: absolute;
		left: 0;
		bottom: -3px;
		width: 0%;
		height: 3px;
		background-color: #667eea;
		transition: width 0.4s ease-in-out;
	}

	.a:hover::after {
